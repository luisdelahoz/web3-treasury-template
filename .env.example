# Copy this file to .env.local for local development
# Set these same variables in Netlify / Vercel dashboard

# Blockchain APIs (free at etherscan.io / polygonscan.com)
VITE_ETHERSCAN_KEY=your_etherscan_api_key_here
VITE_POLYGONSCAN_KEY=your_polygonscan_api_key_here

# Supabase (Settings → API in your Supabase project)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
